# AgentLair credentials
# Option A: Let demo.py register a new agent automatically (leave these blank)
# Option B: Register manually and paste credentials here

# Get credentials by running:
#   curl -X POST https://agentlair.dev/v1/auth/agent-register \
#     -H "Content-Type: application/json" \
#     -d '{"name":"my-crewai-agent"}'

AGENTLAIR_API_KEY=al_live_...
AGENTLAIR_EMAIL=my-agent@agentlair.dev
AGENTLAIR_ACCOUNT_ID=acc_...

# Optional: 32-byte hex seed for vault encryption (generated automatically if blank)
# WARNING: Save this! You cannot decrypt vault secrets without it.
AGENTLAIR_VAULT_SEED=

# LLM credentials (required for CrewAI agents)
# CrewAI uses OpenAI by default; set OPENAI_API_KEY or configure a different model
OPENAI_API_KEY=sk-...

# Or use a local/open model:
# OPENAI_API_BASE=http://localhost:11434/v1
# OPENAI_MODEL_NAME=llama3.2
